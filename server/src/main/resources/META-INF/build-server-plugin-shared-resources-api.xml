<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="sharedResourcesApiController"
          class="com.playgroundgames.teamcity.sharedresources.SharedResourcesApiController">
        <!-- webManager and projectManager are Spring beans provided by TC -->
        <constructor-arg ref="webManager"/>
        <constructor-arg ref="projectManager"/>
    </bean>

</beans>
