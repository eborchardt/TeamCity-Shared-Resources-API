<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="sharedResourcesSettings"
          class="com.example.teamcity.sharedresources.SharedResourcesSettings">
        <constructor-arg ref="serverPaths"/>
    </bean>

    <bean id="sharedResourcesAdminController"
          class="com.example.teamcity.sharedresources.SharedResourcesAdminController">
        <constructor-arg ref="sharedResourcesSettings"/>
    </bean>

    <bean id="sharedResourcesApiController"
          class="com.example.teamcity.sharedresources.SharedResourcesApiController">
        <constructor-arg ref="projectManager"/>
        <constructor-arg ref="sharedResourcesSettings"/>
    </bean>

</beans>
